# Fusion Creative Station - Environment Variables
# Copy this file to .env and fill in your actual values

# Station Identity
STATION_ID=fusion-creative-01
MANAGER_OS_URL=https://manageros.co.uk
WEBHOOK_URL=http://localhost:5678

# Database (PostgreSQL)
DB_PASSWORD=your_secure_database_password_here

# n8n Authentication
N8N_USER=admin
N8N_PASSWORD=your_n8n_admin_password_here

# Apollo.io API (for lead scraping)
# Get your API key from: https://app.apollo.io/#/settings/integrations
APOLLO_API_KEY=your_apollo_api_key_here

# GoHighLevel API (for CRM sync)
# Get your API key from GHL Settings > Business Profile > API Key
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# Email Service (Resend recommended)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=audits@fusioncreative.co.uk

# LinkedIn (for connection automation)
# WARNING: Use with caution - LinkedIn has strict rate limits
LINKEDIN_EMAIL=your_linkedin_email
LINKEDIN_PASSWORD=your_linkedin_password

# Tailscale (optional - for remote access)
# TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxx

# OpenAI/Claude (fallback if Ollama fails)
# OPENAI_API_KEY=sk-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Security
JWT_SECRET=your_random_jwt_secret_here
ENCRYPTION_KEY=your_encryption_key_here
